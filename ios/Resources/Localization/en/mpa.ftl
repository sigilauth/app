# Multi-party authorization (never abbreviate to "MPA" per D7 + Cora §3.2)
mpa-request-title = Approval Required
mpa-action = { $serverName } requests approval for { $actionDescription }
mpa-progress = { $approved } of { $required } people required
mpa-status-pending = Pending
mpa-status-approved = Approved
mpa-status-rejected = Rejected
mpa-status-expired = Expired

# Group-based messaging
mpa-your-group-approved = Your group has approved
mpa-waiting-others = Waiting for other approvers
mpa-clear-notification = No action needed - another device in your group approved
mpa-quorum-reached = Approval complete

# Approver list
approver-pending = { $name } - Pending
approver-approved = { $name } - Approved at { $time }
approver-rejected = { $name } - Rejected
